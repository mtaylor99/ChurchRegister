# ─────────────────────────────────────────────────────────────────────────────
# Playwright E2E Test Environment Variables
#
# Copy this file to .env.test and fill in the values for your local or CI
# environment. The .env.test file is gitignored and must NEVER be committed.
#
# Usage:
#   cp .env.test.example .env.test
#   # Edit .env.test with your values, then run:
#   npm run test:e2e
# ─────────────────────────────────────────────────────────────────────────────

# URL of the React dev server (must be running before tests start)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# URL of the ChurchRegister API service
PLAYWRIGHT_API_URL=http://localhost:5502

# Admin credentials — must exist in the test database before the suite runs
TEST_ADMIN_EMAIL=admin@churchregister.com
TEST_ADMIN_PASSWORD=AdminPassword123!
